#!/usr/bin/env bash
set -euo pipefail

# ─── Colors ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

info()    { echo -e "${GREEN}✓${NC} $*"; }
warn()    { echo -e "${YELLOW}⚠${NC} $*"; }
error()   { echo -e "${RED}✗${NC} $*" >&2; }
header()  { echo -e "\n${BOLD}${CYAN}$*${NC}"; }

# ─── Usage ────────────────────────────────────────────────────────────────────
usage() {
    cat <<'EOF'
review-pr — Review PRs with Claude Code in an isolated worktree

USAGE:
    review-pr                           Review current branch
    review-pr <branch|PR#> [base]       Review a specific branch or PR
    review-pr --cleanup                 Remove all review worktrees
    review-pr --list                    List active review sessions
    review-pr --completions [zsh|bash]  Output shell completions
    review-pr --help                    Show this help

EXAMPLES:
    review-pr                       Review current branch (must not be on base)
    review-pr 42                    Review PR #42
    review-pr feat/login            Review branch feat/login
    review-pr feat/login develop    Review against develop (instead of default base)
    review-pr --cleanup             Clean up all review worktrees
EOF
}

# ─── Helpers ──────────────────────────────────────────────────────────────────
require_cmd() {
    command -v "$1" &>/dev/null || { error "'$1' is required but not found in PATH."; exit 1; }
}

require_git_repo() {
    git rev-parse --is-inside-work-tree &>/dev/null || { error "Not inside a git repository."; exit 1; }
}

get_default_base() {
    local ref
    if ref=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null); then
        echo "${ref#refs/remotes/origin/}"
    else
        echo "main"
    fi
}

slugify() {
    echo "$1" | tr '/' '-' | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]//g'
}

get_repo_root() {
    git rev-parse --show-toplevel
}

# Zed expects worktrees at <parent>/worktrees/<repo-name>/
get_wt_dir() {
    local repo_root repo_name
    repo_root=$(get_repo_root)
    repo_name=$(basename "$repo_root")
    echo "$(dirname "$repo_root")/worktrees/${repo_name}"
}

# ─── List ─────────────────────────────────────────────────────────────────────
cmd_list() {
    header "Active review sessions"
    local found=false
    local repo_root wt_dir
    repo_root=$(get_repo_root)
    wt_dir=$(get_wt_dir)

    while IFS= read -r line; do
        local wt_path wt_branch
        wt_path=$(echo "$line" | awk '{print $1}')
        wt_branch=$(echo "$line" | awk '{print $3}' | tr -d '[]')
        if [[ "$wt_path" == "$wt_dir/"* ]]; then
            found=true
            local created
            created=$(stat -c '%y' "$wt_path" 2>/dev/null | cut -d'.' -f1 || echo "unknown")
            echo -e "  ${CYAN}${wt_branch}${NC}  →  ${wt_path}  (${created})"
        fi
    done < <(git -C "$repo_root" worktree list)

    if [[ "$found" == false ]]; then
        warn "No active review sessions."
    fi
}

# ─── Cleanup ──────────────────────────────────────────────────────────────────
cmd_cleanup() {
    header "Cleaning up review worktrees"
    local found=false
    local repo_root wt_dir
    repo_root=$(get_repo_root)
    wt_dir=$(get_wt_dir)

    while IFS= read -r line; do
        local wt_path wt_branch
        wt_path=$(echo "$line" | awk '{print $1}')
        wt_branch=$(echo "$line" | awk '{print $3}' | tr -d '[]')
        if [[ "$wt_path" == "$wt_dir/"* ]]; then
            found=true
            echo -n "  Removing $wt_path ... "
            git -C "$repo_root" worktree remove --force "$wt_path" 2>/dev/null && info "done" || warn "failed"
            # Clean up the review branch too
            if [[ "$wt_branch" == review/* ]]; then
                git -C "$repo_root" branch -D "$wt_branch" 2>/dev/null || true
            fi
        fi
    done < <(git -C "$repo_root" worktree list)

    if [[ "$found" == false ]]; then
        info "Nothing to clean up."
    else
        git -C "$repo_root" worktree prune
        info "Worktree list pruned."
    fi

    rmdir "$wt_dir" 2>/dev/null || true
}

# ─── Generate CLAUDE.md ──────────────────────────────────────────────────────
generate_claude_md() {
    local wt_path="$1" branch="$2" base="$3" review_branch="$4"
    local ctx="$wt_path/CLAUDE.md"

    {
        cat <<'HEADER'
# Review Mode — Verso (read-only)

You are **Verso**, the code guardian, operating in a **read-only PR review worktree**.

All PR changes are staged (visible via `git diff --cached`). The diff is a patch applied on the base branch — this is NOT the real branch.

## Strict Rules

- **NEVER commit** — not even CLAUDE.md, not even "fix" commits
- **NEVER push** — this worktree is read-only
- **NEVER modify any file** — no edits, no writes, no fixes
- **NEVER use** the Edit, Write, or NotebookEdit tools
- You are here to **read, explain, and advise** — nothing else

## Your Role

1. **Answer questions** about the code: explain logic, patterns, design choices
2. **Identify issues** when asked: bugs, code smells, security concerns, simplification opportunities
3. **Generate prompts for Alicia** when improvements are needed (see below)

## Generating Prompts for Alicia

When you identify an improvement (or the user asks "should this be extracted?", "is this right?", etc.), propose a **copy-paste-ready prompt** for Alicia (`/dev`) on the real branch.

Format each prompt in a fenced block:

```prompt
[High-level description of what needs to change and why]
[Which file(s) / area of the code is concerned]
[Expected behavior or outcome — NOT the technical solution, unless trivial]
```

**Prompt guidelines:**
- Describe the **need**, not the implementation (let Alicia choose the technical approach)
- Be specific enough that Alicia knows exactly *what* to address
- Be high-level enough that she has freedom on *how* to solve it
- Exception: if the fix is trivial (rename, typo, missing import), just say what to do
- One prompt per concern — don't bundle unrelated issues

HEADER

        # PR info from gh if available
        if command -v gh &>/dev/null; then
            local pr_json
            pr_json=$(gh pr list --head "$branch" --json number,title,body,author,isDraft,url --limit 1 2>/dev/null || echo "")
            if [[ -n "$pr_json" && "$pr_json" != "[]" ]]; then
                local pr_title pr_author pr_number pr_url pr_draft pr_body
                pr_number=$(echo "$pr_json" | jq -r '.[0].number')
                pr_title=$(echo "$pr_json" | jq -r '.[0].title')
                pr_author=$(echo "$pr_json" | jq -r '.[0].author.login')
                pr_url=$(echo "$pr_json" | jq -r '.[0].url')
                pr_draft=$(echo "$pr_json" | jq -r '.[0].isDraft')
                pr_body=$(echo "$pr_json" | jq -r '.[0].body // ""')

                echo "## PR"
                echo ""
                echo "- **#${pr_number}** — ${pr_title}"
                echo "- **Author:** ${pr_author}"
                echo "- **URL:** ${pr_url}"
                [[ "$pr_draft" == "true" ]] && echo "- **Draft**"
                echo ""
                if [[ -n "$pr_body" && "$pr_body" != "null" ]]; then
                    echo "### Description"
                    echo ""
                    echo "$pr_body"
                    echo ""
                fi
            fi
        fi

        echo "## Context"
        echo ""
        echo "- **Branch:** \`${branch}\`"
        echo "- **Base:** \`${base}\`"
        echo ""

        echo "### Files changed"
        echo ""
        echo '```'
        git -C "$wt_path" diff --cached --stat 2>/dev/null || echo "(no staged changes)"
        echo '```'

    } > "$ctx"
}

# ─── Main: start review ──────────────────────────────────────────────────────
cmd_review() {
    local target="${1:-}"
    local base="${2:-}"
    local branch=""

    require_cmd git
    require_git_repo

    local repo_root
    repo_root=$(get_repo_root)

    # No argument: use current branch
    if [[ -z "$target" ]]; then
        target=$(git -C "$repo_root" branch --show-current)
        local default_base
        default_base=$(get_default_base)
        if [[ "$target" == "$default_base" ]]; then
            error "You are on '${target}' (base branch). Switch to a PR branch or pass a branch/PR# as argument."
            exit 1
        fi
        info "Using current branch: ${target}"
    fi

    # Resolve PR number to branch name
    if [[ "$target" =~ ^[0-9]+$ ]]; then
        if ! command -v gh &>/dev/null; then
            error "gh CLI is required to resolve PR numbers. Install it or pass a branch name."
            exit 1
        fi
        header "Resolving PR #${target}"
        branch=$(gh pr view "$target" --json headRefName -q '.headRefName') || {
            error "Could not resolve PR #${target}. Does it exist?"
            exit 1
        }
        info "PR #${target} → branch ${branch}"
    else
        branch="$target"
    fi

    # Resolve base branch
    if [[ -z "$base" ]]; then
        base=$(get_default_base)
        info "Using default base: ${base}"
    fi

    # Ensure we have the branch locally (fetch if needed)
    local branch_ref="$branch"
    if ! git -C "$repo_root" rev-parse --verify "$branch" &>/dev/null; then
        warn "Branch '${branch}' not found locally, fetching..."
        git -C "$repo_root" fetch origin "$branch" || {
            error "Could not fetch origin/${branch}."
            exit 1
        }
        branch_ref="origin/${branch}"
        info "Using ${branch_ref}"
    fi

    # Ensure base is up to date
    git -C "$repo_root" fetch origin "$base" &>/dev/null || true

    # Create worktree on base branch, apply PR diff as staged
    local slug wt_dir wt_path
    slug=$(slugify "$branch")
    wt_dir=$(get_wt_dir)
    mkdir -p "$wt_dir"
    wt_path="$wt_dir/${slug}"
    local review_branch="review/${branch}"
    local base_ref="origin/${base}"

    if [[ -d "$wt_path" ]]; then
        warn "Review worktree already exists, reusing: ${wt_path}"
    else
        header "Creating worktree"

        # Create a review branch starting from the base
        git -C "$repo_root" worktree add -b "$review_branch" "$wt_path" "$base_ref" || {
            # Branch might already exist from a previous review
            git -C "$repo_root" branch -D "$review_branch" 2>/dev/null || true
            git -C "$repo_root" worktree add -b "$review_branch" "$wt_path" "$base_ref" || {
                error "Failed to create worktree."
                echo "  Run 'review-pr --list' to see active sessions."
                exit 1
            }
        }
        info "Worktree created on base '${base}'"

        # Apply the full PR diff as staged changes
        header "Applying PR diff as staged changes"
        git -C "$repo_root" diff "${base_ref}...${branch_ref}" | git -C "$wt_path" apply --index || {
            error "Failed to apply PR diff. There may be conflicts."
            exit 1
        }
        info "All PR changes are now staged — browse them in Zed"
    fi

    # Generate CLAUDE.md (auto-read by Claude Code)
    generate_claude_md "$wt_path" "$branch" "$base_ref" "$review_branch"
    info "CLAUDE.md generated"

    # Summary
    header "Review session ready"
    echo ""
    echo -e "  ${BOLD}Path:${NC}    ${wt_path}"
    echo -e "  ${BOLD}Branch:${NC}  ${branch}"
    echo -e "  ${BOLD}Base:${NC}    ${base}"
    echo ""
    echo "  Switch to the worktree in Zed, then open Claude Code."
}

# ─── Completions ─────────────────────────────────────────────────────────────
cmd_completions() {
    local shell="${1:-zsh}"
    case "$shell" in
        zsh)
            cat <<'COMP'
#compdef review-pr

_review-pr() {
    if (( CURRENT == 2 )); then
        # First arg: options or branch/PR#
        local -a opt_vals opt_display branches
        opt_vals=('--cleanup' '--list' '--help' '-h')
        opt_display=('--cleanup  -- Remove all review worktrees' '--list     -- List active review sessions' '--help     -- Show help' '-h         -- Show help')
        compadd -d opt_display -a opt_vals
        branches=(${(f)"$(git branch -r 2>/dev/null | sed 's|origin/||;s/^[* ]*//' | grep -v HEAD)"})
        compadd -a branches
    elif (( CURRENT == 3 )); then
        # Second arg: base branch
        local -a branches
        branches=(${(f)"$(git branch -r 2>/dev/null | sed 's|origin/||;s/^[* ]*//' | grep -v HEAD)"})
        compadd -a branches
    fi
}

_review-pr "$@"
COMP
            ;;
        bash)
            cat <<'COMP'
_review_pr() {
    local cur opts branches
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"

    if [[ ${COMP_CWORD} -eq 1 ]]; then
        opts="--cleanup --list --help -h"
        branches=$(git branch -r 2>/dev/null | sed 's|origin/||;s/^[* ]*//' | grep -v HEAD)
        COMPREPLY=( $(compgen -W "${opts} ${branches}" -- "${cur}") )
    elif [[ ${COMP_CWORD} -eq 2 ]]; then
        branches=$(git branch -r 2>/dev/null | sed 's|origin/||;s/^[* ]*//' | grep -v HEAD)
        COMPREPLY=( $(compgen -W "${branches}" -- "${cur}") )
    fi
}

complete -F _review_pr review-pr
COMP
            ;;
        *)
            error "Unsupported shell: ${shell}. Use 'zsh' or 'bash'."
            exit 1
            ;;
    esac
}

# ─── Entrypoint ───────────────────────────────────────────────────────────────
main() {
    if [[ $# -gt 0 ]]; then
        case "$1" in
            --help|-h)       usage; exit 0 ;;
            --cleanup)       cmd_cleanup; exit 0 ;;
            --list)          cmd_list; exit 0 ;;
            --completions)   cmd_completions "${2:-zsh}"; exit 0 ;;
        esac
    fi

    cmd_review "${1:-}" "${2:-}"
}

main "$@"
